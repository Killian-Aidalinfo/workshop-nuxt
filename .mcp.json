{
    "mcpServers": {
        "nuxt": {
            "command": "npx",
            "args": [
                "mcp-remote",
                "https://nuxt.com/mcp"
            ]
        },
        "nuxt-ui": {
            "command": "npx",
            "args": [
                "mcp-remote",
                "https://ui.nuxt.com/mcp"
            ]
        },
        "better-auth": {
            "command": "npx",
            "args": [
                "mcp-remote",
                "https://mcp.better-auth.com/mcp"
            ]
        },
        "mastra": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@mastra/mcp-docs-server@latest"
            ]
        }
    }
}